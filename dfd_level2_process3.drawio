          <mxGeometry x="920" y="1400" width="800" height="120" as="geometry"/>
        </mxCell>
        
        <mxCell id="summary_text" value="Internal Flow Sequence:&#xa;1. Load findings → 2. Classify by bug type → 3. Calculate priorities&#xa;4. Remove duplicates → 5. Select sanitizers → 6. Generate metadata&#xa;7. Assemble final plan&#xa;&#xa;Key Decision Points:&#xa;• Bug classification determines sanitizer selection&#xa;• Priority calculation influences target ordering&#xa;• Deduplication ensures efficient fuzzing resource usage" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
