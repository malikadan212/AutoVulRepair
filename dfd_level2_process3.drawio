        <mxCell id="balance_box" value="LEVEL-1 TO LEVEL-2 BALANCING VERIFICATION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1400" width="800" height="120" as="geometry"/>
        </mxCell>
        
        <mxCell id="balance_text" value="✓ INPUTS from Level-1 Process 3:&#xa;  • static findings (from Process 2)&#xa;  • findings data (from D3: Analysis Findings)&#xa;&#xa;✓ OUTPUTS from Level-1 Process 3:&#xa;  • fuzz targets (to Process 4)&#xa;  • fuzz plan (to D4: Fuzz Plans)&#xa;&#xa;All boundary flows are preserved with identical names and connections." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
