        <!-- SUB-PROCESS DESCRIPTIONS BOX -->
        <mxCell id="desc_box" value="SUB-PROCESS DESCRIPTIONS (Process 3 Decomposition)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1230" width="1640" height="140" as="geometry"/>
        </mxCell>
        
        <mxCell id="desc_text" value="3.1 Load Static Findings - Read and parse vulnerability data from static analysis results&#xa;&#xa;3.2 Infer Bug Classes - Classify vulnerabilities by type (OOB, UAF, Integer-UB, Null-Deref, Format-String, etc.)&#xa;&#xa;3.3 Calculate Priorities - Compute priority scores based on severity, confidence, bug class, and CWE mappings&#xa;&#xa;3.4 Deduplicate Targets - Remove duplicate findings by grouping on file and function, keeping highest priority&#xa;&#xa;3.5 Select Sanitizers - Choose appropriate sanitizers (ASan, UBSan, MSan, TSan) based on bug class&#xa;&#xa;3.6 Generate Target Metadata - Create complete target specifications with seeds, dictionaries, and harness types&#xa;&#xa;3.7 Assemble Fuzz Plan - Combine all target metadata into structured fuzz plan with statistics and validation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="90" y="1260" width="1620" height="100" as="geometry"/>
        </mxCell>
        
