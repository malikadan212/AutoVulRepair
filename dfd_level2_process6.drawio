        <mxCell id="desc_box" value="SUB-PROCESS DESCRIPTIONS (Process 6 Decomposition)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
