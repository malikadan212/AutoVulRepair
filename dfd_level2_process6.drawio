        </mxCell>
        
        <mxCell id="balance_text" value="✓ INPUTS from Level-1 Process 6:&#xa;  • crash data (from Process 5)&#xa;  • crash files (from D6: Crash Artifacts)&#xa;  • static findings (from D3: Analysis Findings)&#xa;&#xa;✓ OUTPUTS from Level-1 Process 6:&#xa;  • triaged vulnerabilities (to Process 7)&#xa;&#xa;All boundary flows are preserved with identical names and connections." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
