        </mxCell>
        
        <mxCell id="desc_text" value="6.1 Load Crash Data - Read crash files, sanitizer reports, and crash inputs from fuzzing campaign artifacts&#xa;&#xa;6.2 Analyze Stack Traces - Parse stack traces, identify crash locations, extract function call chains, and determine crash types&#xa;&#xa;6.3 Deduplicate Crashes - Group crashes by signature (crash location + type), remove duplicates, identify unique vulnerabilities&#xa;&#xa;6.4 Assess Severity - Evaluate exploitability, impact, and risk level; assign CVSS scores and priority ratings&#xa;&#xa;6.5 Identify Root Cause - Correlate crashes with static analysis findings, determine vulnerability type, and identify vulnerable code patterns&#xa;&#xa;6.6 Generate Reproduction Steps - Create minimal test cases, document reproduction procedures, and prepare debugging information&#xa;&#xa;6.7 Compile Triage Report - Aggregate all triage data, create vulnerability summaries, and prepare actionable findings for reporting" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="90" y="1260" width="1620" height="100" as="geometry"/>
        </mxCell>
        
