        <mxCell id="leg_flow_text" value="data flow (noun phrase)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="1160" width="160" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="note1" value="Note: All processes are numbered (1-8)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="860" y="1140" width="250" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="note2" value="Note: All data stores are labeled (D1-D8)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="860" y="1165" width="270" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="note3" value="Note: Data flows use noun phrases only" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="860" y="1190" width="270" height="20" as="geometry"/>
        </mxCell>
        
        <!-- PROCESS DESCRIPTIONS BOX -->
        <mxCell id="desc_box" value="PROCESS DESCRIPTIONS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1250" width="800" height="120" as="geometry"/>
        </mxCell>
        
        <mxCell id="desc_text" value="1. Receive and Validate Input - Accept code submissions, authenticate users, validate inputs&#xa;2. Perform Static Analysis - Execute Cppcheck/CodeQL on source code to detect vulnerabilities&#xa;3. Generate Fuzz Plan - Create fuzzing targets from static analysis findings&#xa;4. Generate Harnesses - Produce LibFuzzer-compatible test harnesses for each target&#xa;5. Execute Fuzzing - Run fuzzing campaigns to discover crashes and vulnerabilities&#xa;6. Triage Results - Analyze crashes, deduplicate, and assess severity&#xa;7. Generate Reports - Create vulnerability reports, patches, and reproduction kits&#xa;8. Manage Resources - Coordinate container orchestration and system resources" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="90" y="1280" width="780" height="80" as="geometry"/>
        </mxCell>
        
        <!-- DATA STORE DESCRIPTIONS BOX -->
        <mxCell id="store_box" value="DATA STORE DESCRIPTIONS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="1250" width="800" height="120" as="geometry"/>
        </mxCell>
        
        <mxCell id="store_text" value="D1. Source Code - Uploaded or cloned source files&#xa;D2. Scan Records - Metadata about scan sessions and configurations&#xa;D3. Analysis Findings - Raw vulnerability data from static analysis tools&#xa;D4. Fuzz Plans - Structured fuzzing targets with priorities and metadata&#xa;D5. Harness Code - Generated fuzzing harness source and compiled binaries&#xa;D6. Crash Artifacts - Crash dumps, inputs, and stack traces from fuzzing&#xa;D7. Vulnerability Reports - Formatted reports with patches and reproduction steps&#xa;D8. System Metrics - Performance data, resource usage, and health statistics" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="930" y="1280" width="780" height="80" as="geometry"/>
        </mxCell>
        
      </root>
    </mxGraphModel>
