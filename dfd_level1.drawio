        </mxCell>
        
        <mxCell id="f33" value="resource allocation" style="endArrow=classic;html=1;exitX=0.25;exitY=0;entryX=0.75;entryY=1;strokeWidth=2;fontSize=11;strokeColor=#000000;" edge="1" parent="1" source="p8" target="p5">
