        </mxCell>
        
        <!-- LEGEND -->
        <mxCell id="legend_box" value="LEGEND - Gane &amp; Sarson Notation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1100" width="1640" height="120" as="geometry"/>
