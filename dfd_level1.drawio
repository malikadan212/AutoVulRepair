        <mxCell id="leg_entity" value="External Entity" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="1140" width="120" height="50" as="geometry"/>
        </mxCell>
        
        <mxCell id="leg_process" value="1&#xa;Process" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#000000;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="260" y="1140" width="60" height="60" as="geometry"/>
