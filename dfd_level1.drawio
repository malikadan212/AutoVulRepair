        <mxCell id="leg_datastore" value="D1    Data Store" style="shape=partialRectangle;whiteSpace=wrap;html=1;left=0;right=0;fillColor=none;strokeColor=#000000;fontSize=11;strokeWidth=2;align=left;" vertex="1" parent="1">
