            <mxPoint x="450" y="550" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- P5 to P8 (resource coordination) -->
        <mxCell id="f32" value="resource requests" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;fontSize=11;strokeColor=#000000;" edge="1" parent="1" source="p5" target="p8">
