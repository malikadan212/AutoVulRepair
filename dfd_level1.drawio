        <mxCell id="f31" value="aggregated metrics" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=1;strokeWidth=2;fontSize=11;strokeColor=#000000;" edge="1" parent="1" source="d8" target="monitoring">
