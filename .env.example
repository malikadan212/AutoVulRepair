# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-generate-with-python-secrets
PORT=5000

# Database Configuration
DATABASE_PATH=./scans.db

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# File Storage
SCANS_DIR=./scans

# GitHub OAuth credentials (optional - for user authentication)
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# LLM API Keys (required for AI-powered repair and patching)
# Get Groq API key from: https://console.groq.com/keys (FREE - Primary)
GROQ_API_KEY=your-groq-api-key

# Get Gemini API key from: https://makersuite.google.com/app/apikey (Required for AI patching)
GEMINI_API_KEY=your-gemini-api-key
