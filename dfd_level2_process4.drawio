        <!-- SUB-PROCESS DESCRIPTIONS BOX -->
        <mxCell id="desc_box" value="SUB-PROCESS DESCRIPTIONS (Process 4 Decomposition)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1230" width="1640" height="140" as="geometry"/>
        </mxCell>
        
        <mxCell id="desc_text" value="4.1 Extract Function Signatures - Parse source code to extract function declarations, return types, and parameter lists&#xa;&#xa;4.2 Map Parameters - Analyze parameter types and create mappings for fuzzer input generation (int, string, buffer, etc.)&#xa;&#xa;4.3 Select Template - Choose appropriate harness template based on bug class and harness type (bytes-to-api, parser-wrapper, fdp-adapter, api-sequence)&#xa;&#xa;4.4 Generate Harness Code - Instantiate template with target-specific code, parameter handling, and LibFuzzer integration&#xa;&#xa;4.5 Compile Harnesses - Build harness binaries with appropriate sanitizers (ASan, UBSan, MSan) and fuzzing instrumentation&#xa;&#xa;4.6 Generate Build Scripts - Create CMakeLists.txt, Makefiles, and build documentation for harness compilation&#xa;&#xa;4.7 Package Harnesses - Bundle compiled binaries, source code, build scripts, and documentation into deliverable package" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="90" y="1260" width="1620" height="100" as="geometry"/>
        </mxCell>
        
        <!-- BALANCING VERIFICATION BOX -->
        <mxCell id="balance_box" value="LEVEL-1 TO LEVEL-2 BALANCING VERIFICATION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;verticalAlign=top;align=left;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1400" width="800" height="120" as="geometry"/>
        </mxCell>
        
        <mxCell id="balance_text" value="✓ INPUTS from Level-1 Process 4:&#xa;  • fuzz targets (from Process 3)&#xa;  • target specifications (from D4: Fuzz Plans)&#xa;  • source files (from D1: Source Code)&#xa;&#xa;✓ OUTPUTS from Level-1 Process 4:&#xa;  • compiled harnesses (to Process 5)&#xa;  • harness source (to D5: Harness Code)&#xa;&#xa;All boundary flows are preserved with identical names and connections." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
